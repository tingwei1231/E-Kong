# ─────────────────────────────────────────────────────────────────────────────
# Project Ē-Kóng (會講) — 環境變數範本
# 複製為 .env 並填入實際值；.env 已加入 .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── LINE Messaging API ───────────────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN
LINE_CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET

# ── ngrok ────────────────────────────────────────────────────────────────────
NGROK_AUTH_TOKEN=YOUR_NGROK_AUTH_TOKEN

# ── FastAPI Server ────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── 模型路徑（Colab 預設掛載路徑） ─────────────────────────────────────────────
# GGUF LLM 模型，置於 Google Drive 再掛載以節省啟動時間
LLM_MODEL_PATH=/content/drive/MyDrive/ekong_models/taide-lx-7b-chat.Q4_K_M.gguf
LLM_N_GPU_LAYERS=35       # T4 15GB VRAM 建議值；全量 offload 可調到 -1
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7

# ── Groq API（STT: whisper-large-v3）────────────────────────────────────────
# 前往 https://console.groq.com/ 申請免費 API Key
GROQ_API_KEY=YOUR_GROQ_API_KEY

# ── Whisper 本地設定（已棄用，改用 Groq API）──────────────────────────────────
# WHISPER_MODEL_SIZE=base
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=int8
